---
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-bg/80 backdrop-blur-md border-b border-border"
>
  <div
    class="max-w-[1600px] mx-auto px-8 h-16 flex items-center justify-between"
  >
    <a href="#" class="font-mono font-bold text-lg tracking-tight"
      >Debarka Mondal</a
    >

    <nav class="flex items-center gap-6 text-sm font-medium">
      <a href="#ecosystem" class="hover:text-accent transition-colors"
        >Ecosystem</a
      >
      <a href="#open-source" class="hover:text-accent transition-colors"
        >Open Source</a
      >
      <a href="#contact" class="hover:text-accent transition-colors">Contact</a>
      <span class="text-accent/50 cursor-not-allowed" title="Coming soon"
        >Blog</span
      >

      <a
        href="mailto:debarkamondal@gmail.com"
        class="flex items-center gap-2 border border-text px-4 py-1.5 font-mono text-xs hover:bg-text hover:text-bg transition-all duration-300 ml-2"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-mail"
          ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
            d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
        >
        Hire Me
      </a>

      <div class="w-px h-4 bg-border mx-2"></div>

      <ThemeToggle />
    </nav>
  </div>
</header>
